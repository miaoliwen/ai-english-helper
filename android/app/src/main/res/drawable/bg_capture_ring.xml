<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="5dp" android:color="@android:color/white" />
            <solid android:color="@android:color/transparent" />
            <size android:width="76dp" android:height="76dp" />
        </shape>
    </item>
    <!-- Inner filled circle (pressed state will be handled by ripple) -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
