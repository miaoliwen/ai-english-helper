<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_result"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_result"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="解题结果"
            app:titleTextColor="@color/on_primary"
            app:navigationIcon="@drawable/ic_close"
            app:navigationContentDescription="返回" />

        <!-- Loading section (visible while loading) -->
        <LinearLayout
            android:id="@+id/layout_loading"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            android:padding="@dimen/spacing_lg">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_loading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/primary_light" />

            <TextView
                android:id="@+id/tv_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="AI 正在解析题目..."
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small" />

            <!-- 步骤指示器：流式状态步骤 -->
            <LinearLayout
                android:id="@+id/layout_ocr_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_step_ocr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 OCR 识别图片文字..."
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_step_solve"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="🤖 AI 解题分析..."
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

        </LinearLayout>

        <!-- Result content (visible after loading) -->
        <LinearLayout
            android:id="@+id/layout_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Question Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/spacing_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardCornerRadius="@dimen/corner_md"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Photo preview (only visible for image input) -->
                    <ImageView
                        android:id="@+id/iv_preview"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="fitCenter"
                        android:visibility="gone"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="题目"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_question"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:id="@+id/tv_question_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_caption" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Answer Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardCornerRadius="@dimen/corner_md"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/success">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="答案"
                        android:textColor="@color/on_primary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:textColor="@color/on_primary"
                        android:textSize="@dimen/text_headline"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Analysis Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardCornerRadius="@dimen/corner_md"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="解析"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:lineSpacingExtra="4dp" />

                    <!-- 流式输出指示器 -->
                    <LinearLayout
                        android:id="@+id/layout_streaming_indicator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_streaming_cursor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▌"
                            android:textColor="@color/streaming_cursor"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:text="AI 正在输出..."
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
