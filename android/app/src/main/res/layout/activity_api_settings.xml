<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_settings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="API 设置"
            app:titleTextColor="@color/on_primary"
            app:navigationIcon="@drawable/ic_close"
            app:navigationContentDescription="返回" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- === SECTION: 解题 API === -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="▎解题引擎 (LLM)"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <!-- Current status -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardCornerRadius="@dimen/corner_md"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前 API 状态"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_current_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="加载中..."
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Base URL input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="API 基础地址 (Base URL)"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:helperText="例如: https://your-api.com/"
                app:helperTextEnabled="true"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_base_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- API Key input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="API Key（可选）"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:helperText="留空则不使用认证头"
                app:helperTextEnabled="true"
                app:passwordToggleEnabled="true"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- === SECTION: 视觉模型 OCR (可选) === -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_md"
                android:background="@color/divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▎视觉模型 (OCR 识别) — 可选"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_vision_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ℹ️"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_body"
                    android:padding="@dimen/spacing_xs"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="视觉模型配置说明" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:text="可选 — 仅在使用图片题目时需要。不配置时可直接发送图片给解题引擎处理。"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption" />

            <!-- Vision enabled toggle -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_vision_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/corner_sm"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="自动从图片提取文字"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_vision_toggle_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="开启后先 OCR 提取文字再提交解题引擎"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_vision_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Vision Base URL input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout_vision_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="视觉模型地址 (Vision Base URL)"
                app:boxStrokeColor="@color/secondary"
                app:hintTextColor="@color/secondary"
                app:helperText="默认: https://api.openai.com/v1/，可留空"
                app:helperTextEnabled="true"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_vision_base_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Vision API Key input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout_vision_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="视觉模型 API Key（可选）"
                app:boxStrokeColor="@color/secondary"
                app:hintTextColor="@color/secondary"
                app:helperText="OpenAI API Key 或其他兼容服务密钥"
                app:helperTextEnabled="true"
                app:passwordToggleEnabled="true"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_vision_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Vision Model name input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout_vision_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="模型名称（可选）"
                app:boxStrokeColor="@color/secondary"
                app:hintTextColor="@color/secondary"
                app:helperText="默认: gpt-4o，也可用 gpt-4o-mini, claude-3 等"
                app:helperTextEnabled="true"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_vision_model"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Streaming toggle -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_md"
                android:background="@color/divider" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/corner_sm"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="流式输出"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="逐 token 显示 AI 解析结果"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_streaming"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_sm">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="保存全部设置"
                    app:icon="@drawable/ic_edit"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button" />
            </LinearLayout>

            <!-- Reset to default -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="恢复默认地址"
                app:icon="@drawable/ic_close"
                app:iconGravity="textStart"
                style="@style/Widget.Material3.Button.TextButton"
                android:textColor="@color/text_hint" />

            <!-- Status message -->
            <TextView
                android:id="@+id/tv_settings_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:textColor="@color/success"
                android:textSize="@dimen/text_body_small"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
