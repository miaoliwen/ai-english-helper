# AI 英语解题助手 - 环境变量模板
#
# 当前应用优先通过页面右上角“设置”保存模型配置，方便用户自行填写任意
# OpenAI-compatible API 服务。不要在 VITE_* 环境变量中写入真实 API Key，
# 因为 Vite 会把它们打包进浏览器代码。
#
# 推荐做法：
# 1. 在页面设置里填写模型 ID、Base URL、API Key。
# 2. 生产部署时使用自建代理/Serverless 转发层，把真实密钥放在服务端。
# 3. 浏览器端只保存代理地址或临时测试密钥。

# 可选：前端默认展示的代理地址，不包含密钥。
# VITE_DEFAULT_CHAT_BASE_URL=https://your-proxy.example.com/v1/chat/completions
# VITE_DEFAULT_VISION_BASE_URL=https://your-proxy.example.com/v1/chat/completions

# 可选：默认模型名，只作为表单初始值。
# VITE_DEFAULT_CHAT_MODEL=deepseek-chat
# VITE_DEFAULT_VISION_MODEL=gpt-4o-mini
