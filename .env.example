# AI英语解题助手 - 环境变量模板
# 复制此文件为 .env.local 并填入你的实际 API 密钥

# ==========================================
# 视觉结构化识别 - Mimo V2 Omni
# 用于图片 OCR 及多模态结构化识别
# ==========================================
VITE_MIMO_API_KEY=your_mimo_api_key_here
VITE_MIMO_API_URL=https://api.mimo.ai/v2

# ==========================================
# 主力语言模型 - DeepSeek
# 用于逻辑深度问答与多维度内容解析
# ==========================================
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ==========================================
# 可选：中转/代理服务器配置
# 如需通过自建边缘 Serverless 转发层调用，请配置此项
# ==========================================
# VITE_PROXY_API_URL=https://your-proxy-worker.your-domain.workers.dev