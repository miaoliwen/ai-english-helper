DATABASE_URL="file:/app/data/dev.db"

# 生产部署前请务必修改以下两个密钥为随机字符串！
# 可使用 openssl rand -base64 32 生成
# WARNING: Change these secrets before production deployment!
JWT_SECRET="change-this-to-a-random-secret"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"

PORT=3001

# 使用 docker-compose 时由 nginx 同域反向代理，设为 http://localhost 即可
# 若 Nginx 端口非 80 或使用自定义域名，请相应调整
CORS_ORIGIN=http://localhost
AI_CHAT_API_KEY=
AI_VISION_API_KEY=
AI_CHAT_BASE_URL=https://api.deepseek.com
AI_VISION_BASE_URL=https://api.openai.com
